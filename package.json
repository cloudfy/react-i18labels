{
    "name": "react-i18labels",
    "version": "1.0.0",
    "description": "A React library for internationalization and localization.",
    "author": {
        "name": "cloudfy"
    },
    "license": "MIT",
    "keywords": [
        "react",
        "i18n",
        "l10n",
        "internationalization",
        "localization",
        "icu",
        "intl",
        "translation"
    ],
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsc",
        "test": "jest",
        "lint": "eslint src --ext .ts,.tsx",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "react": ">=17.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.3.0",
        "typescript": "^5.0.0",
        "react": "^18.3.0"
    }
}